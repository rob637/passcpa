# ═══════════════════════════════════════════════════════════════════════════
# VoraPrep — .env template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` (committed-safe values only) and `.env.local`
# (real secrets, never committed). Vite loads both at dev time; `.env.local`
# wins on collisions.
#
# Multi-environment layout:
#   .env.example      — this template (tracked)
#   .env.development  — public DEV Firebase config (tracked)
#   .env.staging      — public STAGING Firebase config (tracked)
#   .env.production   — public PROD Firebase config (tracked)
#   .env              — your local DEV secrets (ignored)
#   .env.local        — per-developer overrides (ignored)
#
# Server-only secrets used by deployed Cloud Functions live in
# Google Secret Manager:
#   firebase functions:secrets:set <NAME> --project <project-id>
#
# See docs/API_KEY_SECURITY.md for the full inventory and rotation cadence.
# ═══════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────
# Firebase — Web SDK (CLIENT-SIDE)
# ─────────────────────────────────────────────────────────────
# These VITE_* values are embedded in the browser bundle and are
# considered public. Lock them down with API-key restrictions in
# GCP Console (HTTP referrers for Web, package + SHA1 for Android/iOS).
VITE_FIREBASE_API_KEY=AIzaSy-your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
# FCM web push (public VAPID key — generate in Firebase Console → Cloud Messaging)
VITE_FIREBASE_VAPID_KEY=

# Set to 'true' to use Firebase emulators for local development
VITE_USE_EMULATORS=false


# ─────────────────────────────────────────────────────────────
# Analytics / Ads (CLIENT-SIDE, public IDs)
# ─────────────────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=
VITE_ENABLE_ANALYTICS=false

# Google Ads conversion tracking — Tools → Conversions → Event snippet
VITE_GOOGLE_ADS_CONVERSION_ID=
VITE_GOOGLE_ADS_SIGNUP_CONVERSION_ID=
VITE_GOOGLE_ADS_TRIAL_CONVERSION_ID=
VITE_GOOGLE_ADS_PURCHASE_CONVERSION_ID=


# ─────────────────────────────────────────────────────────────
# AI Tutor — Google Gemini (CLIENT-SIDE FALLBACK ONLY)
# ─────────────────────────────────────────────────────────────
# Deployed environments route AI tutor calls through the `geminiProxy`
# Cloud Function (the real key lives in Secret Manager as GEMINI_API_KEY).
# This client-side key is used only by:
#   - local dev fallback in src/services/aiService.ts
#   - admin CourseFactory tool
#   - tests
# Get one (free tier OK): https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=


# ─────────────────────────────────────────────────────────────
# Course availability flags (CLIENT-SIDE)
# ─────────────────────────────────────────────────────────────
VITE_ENABLE_CPA_COURSE=true
VITE_ENABLE_EA_COURSE=true
VITE_ENABLE_CMA_COURSE=true
VITE_ENABLE_CIA_COURSE=true
VITE_ENABLE_CFP_COURSE=true
VITE_ENABLE_CISA_COURSE=true


# ─────────────────────────────────────────────────────────────
# Build / environment flags (CLIENT-SIDE)
# ─────────────────────────────────────────────────────────────
VITE_ENVIRONMENT=development          # development | staging | production
VITE_APP_URL=http://localhost:5173
VITE_ENABLE_DEBUG=true


# ═══════════════════════════════════════════════════════════════════════════
# SERVER-ONLY SECRETS — never prefix with VITE_, never ship to browser
# Used only by Node scripts in /scripts and /content_factory.
# Production Cloud Functions read their copies from Google Secret Manager.
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic Claude — content tooling, UX audits
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — content generation scripts
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# HeyGen — content_factory video pipelines
# https://app.heygen.com/settings/api
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Resend — transactional email (also used by Cloud Functions as a Secret)
# https://resend.com/api-keys
RESEND_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════
# Cloud Functions secrets (FOR REFERENCE — DO NOT SET HERE)
# ═══════════════════════════════════════════════════════════════════════════
# These are managed in Google Secret Manager, NOT in any .env file.
# To set: firebase functions:secrets:set NAME --project <project-id>
# To view: firebase functions:secrets:access NAME --project <project-id>
#
#   RESEND_API_KEY                     — transactional email (all envs)
#   STRIPE_SECRET_KEY                  — Stripe payments
#   STRIPE_WEBHOOK_SECRET              — Stripe webhook signature
#   DAILY_CPA_STRIPE_WEBHOOK_SECRET    — daily-cpa subdomain webhook
#   GEMINI_API_KEY                     — AI tutor proxy + content jobs
#   DATAFORSEO_LOGIN                   — keyword research
#   DATAFORSEO_PASSWORD                — keyword research
#   TELNYX_API_KEY                     — daily-cpa SMS
#   TELNYX_PHONE_NUMBER                — daily-cpa SMS
#   TELNYX_PUBLIC_KEY                  — daily-cpa SMS webhook verification
# ═══════════════════════════════════════════════════════════════════════════
