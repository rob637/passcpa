# ─────────────────────────────────────────────────────────────
# Python virtual environments
# ─────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc

# ─────────────────────────────────────────────────────────────
# Environment / secrets — NEVER COMMIT
# ─────────────────────────────────────────────────────────────
# Ignore every .env anywhere in the repo by default…
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local

# …then allow back the tracked, secret-free files.
# (.env.development / .staging / .production hold only public client-side
# Firebase config + GA/Ads IDs — see docs/API_KEY_SECURITY.md.)
!.env.example
!.env.development
!.env.staging
!.env.production
!**/.env.example
!**/.env.template

# Firebase Admin / Google Cloud service account keys
serviceAccountKey.json
serviceAccountKey.*.json
**/service-account*.json
**/*-service-account.json
**/gcp-credentials*.json

# Firebase Auth user exports / PII dumps — NEVER COMMIT
users.json
orphaned-users.json
**/users-export*.json
**/auth-export*.json

# Android signing
*.keystore
*.keystore.base64

# Firebase local state
.firebase/
firebase-debug.log
**/firebase-debug.log

# ─────────────────────────────────────────────────────────────
# IDE / OS
# ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─────────────────────────────────────────────────────────────
# Testing
# ─────────────────────────────────────────────────────────────
coverage/
playwright-report/
test-results/

# UX audit outputs
scripts/ux-audit/reports/
scripts/ux-audit/screenshots/

# SEM output (generated CSVs)
/scripts/sem/output/

# Generated by scripts/sync-content-to-public.cjs (npm run prebuild).
# Source of truth lives in content/.
/public/data/questions/
/public/data/flashcards/


# Beta invite audience snapshots and logs (contain PII)
scripts/.beta-invite-*.json

