rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Users collection - private to each user
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Regular users can update their own profile but NOT the isAdmin field
      allow write: if isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
      
      // Admins can update or delete any user's profile
      allow update, delete: if isAdmin();
      
      // All subcollections under user (study_plan, daily_log, progress, etc.)
      match /{subcollection=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Questions collection - read-only for users, write for admins
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Lessons collection - read-only for users, write for admins
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // TBS collection - read-only for users, write for admins
    match /tbs/{tbsId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Written Communications collection - read-only for users, write for admins
    match /written-communication/{wcId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Topics collection - read-only for users, write for admins
    match /topics/{topicId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Exam sections metadata - read-only
    match /examSections/{sectionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // System Errors - append only
    match /error_logs/{errorId} {
      allow create: if isAuthenticated(); // Users can log errors
      allow read, update, delete: if isAdmin(); // Admin only
    }

    // Waitlist - public write (for landing page signup), admin read
    match /waitlist/{emailId} {
      allow create: if true; // Anyone can sign up for waitlist
      allow read, update, delete: if isAdmin(); // Only admin can view/manage
    }

    // Email suppressions - public write so unsubscribe works for logged-out users.
    // Admin-only read so we don't leak the suppression list.
    match /emailSuppressions/{emailId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }

    // Announcements - admin write, authenticated read
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Feedback - authenticated write, admin read
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Question Reports - authenticated users can report issues, admin can manage
    match /questionReports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Subscriptions - users can read their own, backend handles most writes
    match /subscriptions/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow users to create their own subscription doc (free tier / trial start)
      allow create: if isOwner(userId);
      // Allow users to update only the trials and updatedAt fields (for starting per-exam trials)
      // Note: 'status' is NOT allowed client-side — subscription status changes
      // must come from Stripe webhooks via Cloud Functions (Admin SDK bypasses rules)
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['trials', 'updatedAt']);
      // Admins can fully manage subscription documents
      allow write: if isAdmin();
    }

    // Leaderboard - community stats, daily activity, streaks
    // Users can only create/update their own entry (docId must match uid)
    match /leaderboard/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && request.auth.uid == docId;
      allow delete: if isAdmin();
      
      // Subcollections: daily_stats/dates, daily_stats/user_flags, user_streaks
      match /{subcollection=**} {
        allow read: if isAuthenticated();
        allow create, update: if isAuthenticated() && request.auth.uid == docId;
        allow delete: if isAdmin();
      }
    }

    // Referrals - tracking who referred whom
    match /referrals/{referralId} {
      // Users can read referrals they're part of
      allow read: if isAuthenticated() && 
        (resource.data.referrerId == request.auth.uid || 
         resource.data.referredUserId == request.auth.uid);
      // Users can create a referral record where they are the referred user
      allow create: if isAuthenticated() && 
        request.resource.data.referredUserId == request.auth.uid;
      // No updates or deletes from client
      allow update, delete: if isAdmin();
      // Allow admin read for aggregation
      allow read: if isAdmin();
    }

    // Leads - diagnostic/magnet captures, admin only
    match /leads/{leadId} {
      allow create: if true; // Anyone can submit a lead form
      allow read, update, delete: if isAdmin();
    }

    // Diagnostic Leads - diagnostic tool lead captures
    match /diagnosticLeads/{leadId} {
      allow create: if true; // Anyone can submit diagnostic form
      allow read, update, delete: if isAdmin();
    }

    // Testimonials - user-submitted testimonials
    match /testimonials/{testimonialId} {
      allow create: if isAuthenticated(); // Users can submit testimonials
      allow read: if isAuthenticated(); // Public once submitted
      allow update, delete: if isAdmin();
    }

    // Email logs - tracking sent emails
    match /emailHistory/{emailId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Allow logging emails
      allow update, delete: if isAdmin();
    }

    // Growth metrics - SEO/SEM data
    match /growth/{docId} {
      allow read, write: if isAdmin();
      match /{subcollection=**} {
        allow read, write: if isAdmin();
      }
    }

    // Growth config - SEO/SEM engine configuration
    match /growth_config/{docId} {
      allow read, write: if isAdmin();
    }

    // Growth keywords - tracked SEO keywords
    match /growth_keywords/{docId} {
      allow read, write: if isAdmin();
    }

    // Growth campaigns - SEM campaigns data
    match /growth_campaigns/{docId} {
      allow read, write: if isAdmin();
      match /{subcollection=**} {
        allow read, write: if isAdmin();
      }
    }

    // Growth metrics - daily growth metrics
    match /growth_metrics/{docId} {
      allow read, write: if isAdmin();
    }

    // Growth content - auto-generated articles
    // Public read for published articles (blog); admin can read all + write
    match /growth_content/{docId} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    // LinkedIn story posts - manual storytelling posts for LinkedIn
    match /linkedin_story_posts/{docId} {
      allow read, write: if isAdmin();
    }

    // Growth actions - audit log
    match /growth_actions/{docId} {
      allow read, write: if isAdmin();
    }

    // System config - OAuth tokens, integrations (admin only)
    match /system_config/{docId} {
      allow read, write: if isAdmin();
    }

    // System status - function run status for admin dashboard (admin read, server write)
    match /system_status/{docId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // Communication templates - email/push notification templates (admin only)
    match /communication_templates/{templateId} {
      allow read, write: if isAdmin();
    }

    // Course Factory - admin tool for generating new courses
    // Read: admin only. Write: open for admin UI + Python REST API.
    // Course Factory (Admin UI only)
    // Server uses firebase-admin SDK which bypasses security rules.
    match /courseFactory/{jobId} {
      allow read: if isAdmin();
      allow write: if false; // Only server scripts write
    }

    // Rate limits - server-managed, no client access
    match /rate_limits/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // Processed Stripe events - idempotency tracking, server-managed
    match /processed_stripe_events/{eventId} {
      allow read, write: if false; // Admin SDK only
    }

    // ============================================================================
    // COLLECTION GROUP RULES
    // Required for queries that span across all users' subcollections
    // ============================================================================

    // Sessions collection group - allows admin to query recent sessions across all users
    match /{path=**}/sessions/{sessionId} {
      allow read: if isAdmin();
    }

    // ============================================================================
    // DAILY CPA — SMS product collections (server-managed via Admin SDK)
    // ============================================================================

    match /daily_users/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }

    match /daily_sessions/{sessionId} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }

    match /daily_attempts/{attemptId} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }

    match /daily_streaks/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }

    match /daily_sms_log/{messageId} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }

    match /daily_questions/{section} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }

    match /daily_funnel_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false; // Server-managed via Admin SDK
    }
  }
}
