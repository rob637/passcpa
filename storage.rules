rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // User profile images - matches users/{userId}/profile.{extension}
    match /users/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024 // 5MB max
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Lesson assets (read-only for users)
    match /lessons/{lessonId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only
    }
    
    // Question images (read-only for users)
    match /questions/{questionId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Admin only
    }
    
    // YouTube Shorts - admin write, function read
    match /shorts/{folder}/{fileName} {
      allow read: if false;  // Cloud Functions use admin SDK
      allow write: if false; // Admin uploads via console/CLI only
    }
  }
}
